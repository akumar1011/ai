# AI API Configuration
GROQ_API_KEY=your-groq-api
GROQ_MODEL=llama-3.1-8b-instant

# Ollama Configuration
OLLAMA_MODEL=llama3.2:latest
OLLAMA_BASE_URL=http://localhost:11434

# RSS Feed Configuration
MAX_ARTICLES_PER_DAY=5

# Twitter Configuration
TWITTER_SESSION_PATH=twitter_profile/twitter_session.json
TWITTER_PROFILE_DIR=twitter_profile

# Posting Schedule
POST_TIME_HOUR=10
POST_TIME_MINUTE=30
RANDOM_DELAY_MINUTES=60

# Content Settings
MAX_TWEET_LENGTH=280
MIN_ENGAGEMENT_SCORE=7

# Logging
LOG_LEVEL=INFO

# Tweet History Configuration
TWEET_HISTORY_CSV=data/tweet_history.csv
DUPLICATE_CHECK_DAYS=3

# Hashtag Configuration
HASHTAG_DATABASE_PATH=data/hashtag_database.json
ENABLE_HASHTAGS=true
MAX_HASHTAGS_PER_TWEET=3
